/** 全局样式 */
page {
  --primary: #4CAF82;
  --secondary: #FFC857;
  --bg: #F4F8F4;
  --card: #FFFFFF;
  --text: #2E3A33;
  --text-secondary: #8A9A90;
  --accent: #E8705B;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  background-color: var(--bg);
  color: var(--text);
}

.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
}

.container {
  padding: 30rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom) + 60rpx);
  box-sizing: border-box;
}

.card {
  background: var(--card);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 48rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: var(--secondary);
  color: var(--text);
  border-radius: 48rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-secondary::after {
  border: none;
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  background: rgba(76, 175, 130, 0.12);
  color: var(--primary);
  margin-right: 12rpx;
}

.score-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255, 200, 87, 0.2);
  color: #B07D00;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.title-lg {
  font-size: 40rpx;
  font-weight: 700;
}

.title-md {
  font-size: 32rpx;
  font-weight: 600;
}

.text-sm {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
