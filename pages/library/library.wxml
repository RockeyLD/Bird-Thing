<view class="page">
  <image class="bg-image" src="/images/Background.png" mode="aspectFill" />
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px; padding-right: {{menuButtonRight}}px;">
    <view class="nav-title">知识库</view>
  </view>

  <view class="search-box">
    <input class="search-input" placeholder="搜索鸟名、特征..." bindconfirm="onSearch" bindinput="onSearch" />
    <text class="search-icon">🔍</text>
  </view>

  <view class="content-wrapper">
    <scroll-view scroll-y class="scrollarea">
      <view class="container">
        <view class="bird-card" wx:for="{{filtered}}" wx:key="id" bindtap="onBirdTap" data-id="{{item.id}}">
          <view class="bird-cover">
            <image wx:if="{{item.cover}}" class="bird-cover-img" src="{{item.cover}}" mode="aspectFill" />
            <text wx:else class="bird-emoji">🐦</text>
          </view>
          <view class="bird-info">
            <view class="flex-between">
              <view class="title-md">{{item.name}}</view>
              <view class="tag">{{item.enName}}</view>
            </view>
            <view class="text-sm">{{item.persona || item.desc}}</view>
            <view class="bird-tags">
              <text class="tag" wx:for="{{item.tags}}" wx:for-item="t" wx:key="*this">{{t}}</text>
            </view>
          </view>
        </view>

        <view wx:if="{{filtered.length === 0}}" class="empty-state">
          <text>🍃</text>
          <view class="text-sm">没有找到匹配的鸟类</view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
