.page { display: flex; flex-direction: column; height: 100vh; position: relative; }

.nav-bar { padding-bottom: 20rpx; padding-left: 30rpx; background: var(--bg); }
.nav-title { font-size: 40rpx; font-weight: 700; }

.search-box {
  margin: 0 30rpx 20rpx;
  position: relative;
}

.search-input {
  height: 80rpx;
  background: var(--card);
  border-radius: 40rpx;
  padding: 0 40rpx 0 80rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.search-icon {
  position: absolute;
  left: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
}

.content-wrapper { flex: 1; overflow: hidden; position: relative; }
.scrollarea { position: absolute; top: 0; left: 0; right: 0; bottom: 0; }

.bird-card {
  background: var(--card);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.bird-cover {
  width: 120rpx;
  height: 120rpx;
  background: var(--bg);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bird-cover-img { width: 120rpx; height: 120rpx; border-radius: 20rpx; }
.bird-emoji { font-size: 60rpx; }

.bird-info { flex: 1; }

.bird-tags { margin-top: 10rpx; }

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  font-size: 80rpx;
}

/* 知识卡片弹窗 */
.card-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(0,0,0,0.5);
}

.card-modal-content {
  background: var(--card);
  border-radius: 24rpx;
  padding: 40rpx;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
}

.bird-header-modal { text-align: center; padding: 20rpx 0 30rpx; }
.bird-header-modal .bird-cover-img { width: 200rpx; height: 200rpx; border-radius: 24rpx; margin-bottom: 12rpx; }
.bird-header-modal .bird-emoji { font-size: 100rpx; margin-bottom: 12rpx; }
.bird-header-modal .bird-tags { margin-top: 16rpx; }
.bird-header-modal .tag { display: inline-block; padding: 6rpx 16rpx; border-radius: 24rpx; font-size: 24rpx; background: var(--bg); color: var(--text-secondary); margin-right: 8rpx; }
.bird-header-modal .title-lg { font-size: 40rpx; font-weight: 700; }
.bird-header-modal .text-sm { font-size: 26rpx; color: var(--text-secondary); margin-top: 4rpx; }

.knowledge-card-modal { padding: 24rpx 0; border-top: 1rpx solid rgba(0,0,0,0.06); }
.knowledge-section { margin-bottom: 24rpx; }
.knowledge-section:last-child { margin-bottom: 0; }
.knowledge-section-title { font-size: 30rpx; font-weight: 700; color: var(--primary); margin-bottom: 12rpx; }
.knowledge-text { font-size: 28rpx; line-height: 1.6; color: var(--text-secondary); }

.card-modal-content .btn-primary { margin-top: 20rpx; width: 100%; background: var(--primary); color: #fff; border-radius: 24rpx; font-size: 32rpx; font-weight: 600; padding: 24rpx 0; border: none; }
.card-modal-content .btn-primary:active { transform: scale(0.97); }
