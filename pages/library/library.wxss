.page { display: flex; flex-direction: column; height: 100vh; }

.nav-bar { padding-bottom: 20rpx; padding-left: 30rpx; background: var(--bg); }
.nav-title { font-size: 40rpx; font-weight: 700; }

.search-box {
  margin: 0 30rpx 20rpx;
  position: relative;
}

.search-input {
  height: 80rpx;
  background: var(--card);
  border-radius: 40rpx;
  padding: 0 40rpx 0 80rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.search-icon {
  position: absolute;
  left: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
}

.content-wrapper { flex: 1; overflow: hidden; }
.scrollarea { height: 100%; }

.bird-card {
  background: var(--card);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.bird-cover {
  width: 120rpx;
  height: 120rpx;
  background: var(--bg);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bird-emoji { font-size: 60rpx; }

.bird-info { flex: 1; }

.bird-tags { margin-top: 10rpx; }

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  font-size: 80rpx;
}
