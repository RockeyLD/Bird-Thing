.tutorial-page {
  height: 100vh;
  background: rgba(0, 0, 0, 0.88);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  position: relative;
}

.step-indicator {
  position: absolute;
  top: 140rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  transition: all 0.3s ease;
}

.step-dot.active {
  width: 40rpx;
  border-radius: 8rpx;
  background: #4CAF82;
}

.guide-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 2;
}

.step-badge {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 50rpx;
  padding: 10rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.highlight-area {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 60rpx;
}

.pulse-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx solid rgba(76, 175, 130, 0.3);
  animation: pulse-ring 2s ease-out infinite;
}

@keyframes pulse-ring {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.5); opacity: 0; }
}

.highlight-btn {
  width: 340rpx;
  height: 340rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 0 80rpx rgba(76, 175, 130, 0.25), 0 0 160rpx rgba(76, 175, 130, 0.1), inset 0 0 60rpx rgba(255, 255, 255, 0.05);
  transition: transform 0.2s ease;
  position: relative;
  z-index: 2;
}

.highlight-btn:active {
  transform: scale(0.95);
}

.btn-emoji {
  font-size: 120rpx;
  margin-bottom: 16rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0,0,0,0.3));
}

.btn-label {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.guide-title {
  font-size: 44rpx;
  color: #fff;
  font-weight: 700;
  margin-bottom: 20rpx;
  text-align: center;
}

.guide-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.65);
  line-height: 1.7;
  text-align: center;
  max-width: 540rpx;
}

.skip-link {
  position: absolute;
  bottom: 80rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.45);
  text-decoration: underline;
  padding: 20rpx 40rpx;
}

.skip-link:active {
  color: rgba(255, 255, 255, 0.7);
}
