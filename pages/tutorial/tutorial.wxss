.page {
  height: 100vh;
  background: var(--bg);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 60rpx;
}

.tutorial-content {
  width: 100%;
  max-width: 600rpx;
}

.step-indicator {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 60rpx;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(76, 175, 130, 0.2);
  transition: all 0.3s;
}

.step-dot.active {
  width: 40rpx;
  border-radius: 8rpx;
  background: var(--primary);
}

.step-card {
  background: var(--card);
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
}

.step-emoji { font-size: 120rpx; margin-bottom: 24rpx; }

.step-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-top: 16rpx;
}

.skip-link {
  text-align: center;
  margin-top: 30rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  text-decoration: underline;
}
