<view class="page">
  <image class="bg-image" src="/images/Background.png" mode="aspectFill" />
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px; padding-right: {{menuButtonRight}}px;">
    <view class="nav-title">我的图鉴</view>
    <view class="score-badge">⭐ {{user.totalScore}}</view>
  </view>

  <!-- 筛选器 -->
  <view class="filter-bar">
    <view class="filter-item {{filter === 'all' ? 'active' : ''}}" bindtap="onFilterTap" data-filter="all">全部</view>
    <view class="filter-item {{filter === 'mastered' ? 'active' : ''}}" bindtap="onFilterTap" data-filter="mastered">已精通</view>
    <view class="filter-item {{filter === 'learning' ? 'active' : ''}}" bindtap="onFilterTap" data-filter="learning">学习中</view>
  </view>

  <view class="content-wrapper">
    <scroll-view scroll-y class="scrollarea">
      <view class="container">
        <view class="codex-grid">
          <view
            class="codex-item {{item.mastered ? 'mastered' : item.progress > 0 ? 'learning' : 'locked'}}"
            wx:for="{{birds}}"
            wx:key="id"
            wx:if="{{filter === 'all' || (filter === 'mastered' && item.mastered) || (filter === 'learning' && item.progress > 0 && !item.mastered)}}"
            bindtap="onBirdTap"
            data-id="{{item.id}}"
          >
            <image class="codex-img" src="{{item.iconPath}}" mode="aspectFill" />
            <view class="codex-name">{{item.name}}</view>
            <view class="codex-progress">
              <view class="progress-mini">
                <view class="progress-mini-fill" style="width: {{item.progress / 5 * 100}}%"></view>
              </view>
              <text class="progress-text">{{item.progress}}/5</text>
            </view>
          </view>
        </view>

        <view class="stats-card">
          <view class="stats-title">学习统计</view>
          <view class="stats-row">
            <view class="stats-block">
              <view class="stats-num">{{user.learnedBirdIds.length}}</view>
              <view class="stats-label">已学习</view>
            </view>
            <view class="stats-block">
              <view class="stats-num">{{masteredCount}}</view>
              <view class="stats-label">已精通</view>
            </view>
            <view class="stats-block">
              <view class="stats-num">{{15 - user.learnedBirdIds.length}}</view>
              <view class="stats-label">待探索</view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 鸟类知识卡片弹窗 -->
  <view wx:if="{{showCard}}" class="card-modal" catchtap="onMaskTap">
    <view class="card-modal-inner" catchtap="onContentTap">
      <scroll-view scroll-y class="card-scroll">
        <view class="card-inner-padding">
          <view class="bird-header-modal">
            <image wx:if="{{cardBird.cover}}" class="bird-cover-img" src="{{cardBird.cover}}" mode="aspectFit" />
            <view wx:else class="bird-emoji">🐦</view>
            <view class="title-lg">{{cardBird.name}}</view>
            <view class="text-sm">{{cardBird.enName}}</view>
            <view class="bird-tags">
              <text class="tag" wx:for="{{cardBird.tags}}" wx:for-item="t" wx:key="*this">{{t}}</text>
            </view>
          </view>
          <view class="knowledge-card-modal">
            <view wx:if="{{cardBird.persona}}" class="knowledge-section">
              <view class="knowledge-section-title">🎭 人设</view>
              <view class="knowledge-text">{{cardBird.persona}}</view>
            </view>
            <view wx:if="{{cardBird.identification}}" class="knowledge-section">
              <view class="knowledge-section-title">👁 辨识</view>
              <view class="knowledge-text">{{cardBird.identification}}</view>
            </view>
            <view wx:if="{{cardBird.habit}}" class="knowledge-section">
              <view class="knowledge-section-title">🌿 习性</view>
              <view class="knowledge-text">{{cardBird.habit}}</view>
            </view>
            <view wx:if="{{cardBird.trivia}}" class="knowledge-section">
              <view class="knowledge-section-title">💡 冷知识</view>
              <view class="knowledge-text">{{cardBird.trivia}}</view>
            </view>
            <view wx:if="{{!cardBird.persona}}" class="knowledge-section">
              <view class="knowledge-text">{{cardBird.desc}}</view>
            </view>
          </view>
        </view>
      </scroll-view>
      <button class="btn-primary" bindtap="onStartQuiz">开始答题</button>
    </view>
  </view>
</view>
