.page { display: flex; flex-direction: column; height: 100vh; position: relative; }

.nav-bar { padding-bottom: 20rpx; padding-left: 30rpx; background: var(--bg); display: flex; justify-content: space-between; align-items: center; }
.nav-title { font-size: 40rpx; font-weight: 700; }

.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 0 30rpx 20rpx;
  background: var(--bg);
}

.filter-item {
  padding: 10rpx 28rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  background: var(--card);
  color: var(--text-secondary);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.filter-item.active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
}

.content-wrapper { flex: 1; overflow: hidden; position: relative; }
.scrollarea { position: absolute; top: 0; left: 0; right: 0; bottom: 0; }

.codex-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.codex-item {
  background: var(--card);
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  transition: transform 0.2s;
}

.codex-item.mastered { border: 2rpx solid var(--primary); }
.codex-item.learning { border: 2rpx solid var(--secondary); }
.codex-item.locked { opacity: 1; }

.codex-emoji { font-size: 60rpx; margin-bottom: 8rpx; }
.codex-img { width: 120rpx; height: 120rpx; border-radius: 24rpx; margin-bottom: 8rpx; background: #eee; }
.codex-item.locked .codex-img { filter: grayscale(1) brightness(0.5); }
.codex-item.locked .codex-name,
.codex-item.locked .codex-progress { opacity: 0.5; }
.codex-name { font-size: 26rpx; font-weight: 600; margin-bottom: 8rpx; }

.codex-progress { display: flex; align-items: center; gap: 8rpx; }

.progress-mini {
  flex: 1;
  height: 8rpx;
  background: rgba(0,0,0,0.06);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-mini-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 4rpx;
}

.progress-text { font-size: 20rpx; color: var(--text-secondary); }

.stats-card {
  background: var(--card);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-top: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.stats-title { font-size: 30rpx; font-weight: 700; margin-bottom: 20rpx; }

.stats-row { display: flex; justify-content: space-around; }

.stats-block { text-align: center; }

.stats-num { font-size: 44rpx; font-weight: 700; color: var(--primary); }
.stats-label { font-size: 24rpx; color: var(--text-secondary); margin-top: 6rpx; }

/* 知识卡片弹窗 */
.card-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: rgba(0,0,0,0.5);
}

.card-modal-inner {
  background: var(--card);
  border-radius: 24rpx;
  width: 100%;
  height: 75vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.card-scroll {
  flex: 1;
  overflow: hidden;
}

.card-inner-padding {
  padding: 40rpx 40rpx 0 40rpx;
}

.bird-header-modal { text-align: center; padding: 20rpx 0 30rpx; }
.bird-cover-img { width: 200rpx; height: 200rpx; border-radius: 24rpx; margin-bottom: 12rpx; }
.bird-emoji { font-size: 100rpx; margin-bottom: 12rpx; }
.bird-tags { margin-top: 16rpx; }

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  background: var(--bg);
  color: var(--text-secondary);
  margin-right: 8rpx;
}

.title-lg { font-size: 40rpx; font-weight: 700; }
.text-sm { font-size: 26rpx; color: var(--text-secondary); margin-top: 4rpx; }

.knowledge-card-modal { padding: 24rpx 0; border-top: 1rpx solid rgba(0,0,0,0.06); }
.knowledge-section { margin-bottom: 24rpx; }
.knowledge-section:last-child { margin-bottom: 0; }
.knowledge-section-title { font-size: 30rpx; font-weight: 700; color: var(--primary); margin-bottom: 12rpx; }
.knowledge-text { font-size: 28rpx; line-height: 1.6; color: var(--text-secondary); }

.card-modal-inner .btn-primary { margin: 20rpx 40rpx 40rpx 40rpx; flex-shrink: 0; background: var(--primary); color: #fff; border-radius: 24rpx; font-size: 32rpx; font-weight: 600; height: 88rpx; line-height: 88rpx; padding: 0; border: none; text-align: center; }
.btn-primary { background: var(--primary); color: #fff; border-radius: 24rpx; font-size: 32rpx; font-weight: 600; padding: 24rpx 0; border: none; }
.btn-primary:active { transform: scale(0.97); }
