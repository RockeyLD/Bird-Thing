.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg);
}

.login-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.brand {
  text-align: center;
  margin-bottom: 120rpx;
}

.brand-logo {
  width: 700rpx;
  height: 700rpx;
  margin-bottom: 0rpx;
  display: block;
  margin-left: auto;
  margin-right: auto;
}

.brand-title {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12rpx;
}

.brand-subtitle {
  font-size: 30rpx;
  color: var(--text-secondary);
}

.actions {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.btn-login {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 48rpx;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 130, 0.25);
}

.btn-login::after {
  border: none;
}

.btn-guest {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: var(--card);
  color: var(--text);
  border-radius: 48rpx;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.btn-guest::after {
  border: none;
}

.btn-icon { width: 52rpx; height: 52rpx; }

.btn-login .btn-icon { filter: brightness(0) invert(1); }

.guest-hint {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}
