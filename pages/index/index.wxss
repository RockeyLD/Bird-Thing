.nav-right { display: flex; align-items: center; gap: 16rpx; }

.login-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(76, 175, 130, 0.12);
  color: var(--primary);
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.login-badge.guest {
  background: rgba(232, 112, 91, 0.12);
  color: #E8705B;
}

.login-badge.logged {
  background: rgba(76, 175, 130, 0.08);
  color: var(--primary);
}

.page { display: flex; flex-direction: column; height: 100vh; position: relative; }

.nav-bar {
  padding-bottom: 20rpx;
  padding-left: 30rpx;
  background: var(--bg);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-title { font-size: 40rpx; font-weight: 700; color: var(--text); }

.content-wrapper { flex: 1; overflow: hidden; position: relative; }
.scrollarea { position: absolute; top: 0; left: 0; right: 0; bottom: 0; }

.pet-card { text-align: center; padding: 50rpx 30rpx; }

.pet-egg { font-size: 120rpx; margin-bottom: 20rpx; }

.pet-avatar { width: 200rpx; height: 200rpx; margin: 0 auto 16rpx; display: block; }

.pet-avatar.egg { animation: float 3s ease-in-out infinite; }
.pet-avatar.chick { animation: bounce 2s ease-in-out infinite; }

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}
@keyframes bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.pet-info { margin-bottom: 20rpx; }

.progress-bar {
  height: 16rpx;
  background: rgba(76, 175, 130, 0.15);
  border-radius: 8rpx;
  overflow: hidden;
  margin: 20rpx 0;
}

.progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.adopt-btn { margin-top: 30rpx; }
.feed-btn { margin-top: 20rpx; }

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin: 30rpx 0 20rpx;
}

.action-card {
  background: var(--card);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.action-label { font-size: 28rpx; font-weight: 600; }

.daily-recommend { padding: 24rpx; }

.due-review {
  border: 2rpx solid #ff9800;
}

.recommend-row { display: flex; align-items: center; gap: 24rpx; }
.recommend-img { width: 140rpx; height: 140rpx; border-radius: 20rpx; object-fit: cover; background: #eee; flex-shrink: 0; }
.recommend-info { display: flex; flex-direction: column; gap: 12rpx; }
.recommend-name { font-size: 34rpx; font-weight: 700; color: var(--text); }
.recommend-hook { font-size: 26rpx; color: var(--text-secondary); line-height: 1.4; }

.recommend-card { padding: 30rpx; }
.recommend-content { display: flex; align-items: center; gap: 20rpx; }
.recommend-icon { font-size: 80rpx; }

.stats-card { padding: 30rpx; }
.stats-row { display: flex; align-items: center; justify-content: space-around; margin-bottom: 24rpx; }
.stats-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.stats-num { font-size: 48rpx; font-weight: 700; color: var(--primary); }
.stats-total { font-size: 28rpx; color: var(--text-secondary); font-weight: 500; }
.stats-label { font-size: 26rpx; color: var(--text-secondary); }
.stats-divider { width: 2rpx; height: 60rpx; background: rgba(0,0,0,0.06); }
.stats-progress-bar { height: 12rpx; background: rgba(76, 175, 130, 0.12); border-radius: 6rpx; overflow: hidden; margin-bottom: 12rpx; }
.stats-progress-fill { height: 100%; background: var(--primary); border-radius: 6rpx; transition: width 0.3s ease; }
.stats-progress-text { font-size: 24rpx; color: var(--text-secondary); text-align: center; }

.card-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(0,0,0,0.5);
}

.card-modal-content {
  background: var(--card);
  border-radius: 24rpx;
  padding: 40rpx;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
}

.bird-header-modal { text-align: center; padding: 20rpx 0 30rpx; }
.bird-header-modal .bird-emoji { width: 200rpx; height: 200rpx; border-radius: 20rpx; margin-bottom: 12rpx; display: block; margin-left: auto; margin-right: auto; }
.bird-header-modal .bird-name { font-size: 40rpx; font-weight: 700; color: var(--text); margin-bottom: 12rpx; }
.bird-header-modal .bird-tags { font-size: 26rpx; color: var(--text-secondary); margin-top: 16rpx; }

.knowledge-card-modal { padding: 24rpx 0; border-top: 1rpx solid rgba(0,0,0,0.06); }
.knowledge-section { margin-bottom: 24rpx; }
.knowledge-section:last-child { margin-bottom: 0; }
.knowledge-section-title { font-size: 30rpx; font-weight: 700; color: var(--primary); margin-bottom: 12rpx; }
.knowledge-text { font-size: 28rpx; line-height: 1.6; color: var(--text-secondary); }

.card-btn { margin-top: 20rpx; width: 100%; }
