.nav-right { display: flex; align-items: center; gap: 16rpx; }

.login-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(76, 175, 130, 0.12);
  color: var(--primary);
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.badge-icon { width: 50rpx; height: 50rpx; }

.login-badge.guest {
  background: rgba(232, 112, 91, 0.12);
  color: #E8705B;
}

.login-badge.logged {
  background: rgba(76, 175, 130, 0.08);
  color: var(--primary);
}

.page { display: flex; flex-direction: column; height: 100vh; position: relative; }

.nav-bar {
  padding-bottom: 20rpx;
  padding-left: 30rpx;
  background: var(--bg);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-title { font-size: 40rpx; font-weight: 700; color: var(--text); }

.content-wrapper { flex: 1; overflow: hidden; position: relative; }
.scrollarea { position: absolute; top: 0; left: 0; right: 0; bottom: 0; }

.pet-card { text-align: center; padding: 50rpx 30rpx; }

.pet-egg { width: 120rpx; height: 140rpx; margin: 0 auto 20rpx; display: block; }

.pet-avatar { width: 200rpx; height: 200rpx; margin: 0 auto 16rpx; display: block; }

.pet-avatar.egg { animation: float 3s ease-in-out infinite; }
.pet-avatar.chick { animation: bounce 2s ease-in-out infinite; }

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}
@keyframes bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.pet-info { margin-bottom: 20rpx; }

.progress-bar {
  height: 16rpx;
  background: rgba(76, 175, 130, 0.15);
  border-radius: 8rpx;
  overflow: hidden;
  margin: 20rpx 0;
}

.progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.adopt-btn { margin-top: 30rpx; }
.feed-btn { margin-top: 20rpx; }

.max-badge {
  text-align: center;
  padding: 6rpx;
  background: var(--secondary);
  border-radius: 12rpx;
  font-weight: 700;
  color: #8A6A00;
  margin-top: 6rpx;
  font-size: 22rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin: 30rpx 0 20rpx;
}

.action-card {
  background: var(--card);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.action-label { font-size: 28rpx; font-weight: 600; }

.daily-recommend { padding: 24rpx; }

.due-review {
  border: 2rpx solid #ff9800;
}

.recommend-row { display: flex; align-items: center; gap: 24rpx; }
.recommend-img { width: 140rpx; height: 140rpx; border-radius: 20rpx; object-fit: cover; background: #eee; flex-shrink: 0; }
.recommend-info { display: flex; flex-direction: column; gap: 12rpx; }
.recommend-name { font-size: 34rpx; font-weight: 700; color: var(--text); }
.recommend-hook { font-size: 26rpx; color: var(--text-secondary); line-height: 1.4; }

.recommend-card { padding: 30rpx; }
.recommend-content { display: flex; align-items: center; gap: 20rpx; }
.recommend-icon { font-size: 80rpx; }

.stats-card { padding: 30rpx; }
.stats-row { display: flex; align-items: center; justify-content: space-around; margin-bottom: 24rpx; }
.stats-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.stats-num { font-size: 48rpx; font-weight: 700; color: var(--primary); }
.stats-total { font-size: 28rpx; color: var(--text-secondary); font-weight: 500; }
.stats-label { font-size: 26rpx; color: var(--text-secondary); }
.stats-divider { width: 2rpx; height: 60rpx; background: rgba(0,0,0,0.06); }
.stats-progress-bar { height: 12rpx; background: rgba(76, 175, 130, 0.12); border-radius: 6rpx; overflow: hidden; margin-bottom: 12rpx; }
.stats-progress-fill { height: 100%; background: var(--primary); border-radius: 6rpx; transition: width 0.3s ease; }
.stats-progress-text { font-size: 24rpx; color: var(--text-secondary); text-align: center; }

.card-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(0,0,0,0.5);
}

.card-modal-content {
  background: var(--card);
  border-radius: 24rpx;
  padding: 40rpx;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
}

.bird-header-modal { text-align: center; padding: 20rpx 0 30rpx; }
.bird-header-modal .bird-emoji { width: 200rpx; height: 200rpx; border-radius: 20rpx; margin-bottom: 12rpx; display: block; margin-left: auto; margin-right: auto; }
.bird-header-modal .bird-name { font-size: 40rpx; font-weight: 700; color: var(--text); margin-bottom: 12rpx; }
.bird-header-modal .bird-tags { font-size: 26rpx; color: var(--text-secondary); margin-top: 16rpx; }

.knowledge-card-modal { padding: 24rpx 0; border-top: 1rpx solid rgba(0,0,0,0.06); }
.knowledge-section { margin-bottom: 24rpx; }
.knowledge-section:last-child { margin-bottom: 0; }
.knowledge-section-title { font-size: 30rpx; font-weight: 700; color: var(--primary); margin-bottom: 12rpx; }
.knowledge-text { font-size: 28rpx; line-height: 1.6; color: var(--text-secondary); }

.card-btn { margin-top: 20rpx; width: 100%; }

/* 引导遮罩 */
.guide-mask {
  position: fixed;
  background: rgba(0, 0, 0, 0.75);
  z-index: 200;
}

/* 高亮边框 */
.guide-highlight {
  position: fixed;
  border: 4rpx solid #4CAF82;
  border-radius: 16rpx;
  z-index: 201;
  pointer-events: none;
  animation: guide-pulse 1.5s ease-in-out infinite;
}

@keyframes guide-pulse {
  0%, 100% { box-shadow: 0 0 0 4rpx rgba(76, 175, 130, 0.3), 0 0 20rpx rgba(76, 175, 130, 0.3); }
  50% { box-shadow: 0 0 0 8rpx rgba(76, 175, 130, 0.2), 0 0 40rpx rgba(76, 175, 130, 0.5); }
}

/* 气泡 */
.guide-tooltip {
  position: fixed;
  z-index: 201;
  display: flex;
  flex-direction: column;
  align-items: center;
  max-width: 540rpx;
}

.guide-tooltip-inner {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.2);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.guide-tooltip-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.guide-step-badge {
  font-size: 22rpx;
  color: #999;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.guide-tooltip-arrow {
  width: 0;
  height: 0;
  border-left: 16rpx solid transparent;
  border-right: 16rpx solid transparent;
}

.guide-tooltip.bottom .guide-tooltip-arrow {
  border-bottom: 16rpx solid #fff;
  margin-bottom: -2rpx;
}

.guide-tooltip.top {
  flex-direction: column-reverse;
}

.guide-tooltip.top .guide-tooltip-arrow {
  border-top: 16rpx solid #fff;
  margin-top: -2rpx;
}

/* 底部 Tab Bar 遮罩 */
.guide-mask-tabbar {
  position: fixed;
  bottom: 0;
  height: 120rpx;
  z-index: 200;
}

/* 跳过按钮 */
.guide-skip {
  position: fixed;
  top: 60rpx;
  right: 30rpx;
  z-index: 201;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
  padding: 16rpx 30rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  transition: all 0.2s ease;
  backdrop-filter: blur(4rpx);
}

.guide-skip:active {
  color: #fff;
  background: rgba(255, 255, 255, 0.15);
}
