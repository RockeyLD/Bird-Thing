<view class="page">
  <image class="bg-image" src="/images/Background.png" mode="aspectFill" />
  <!-- 顶部导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px; padding-right: {{menuButtonRight}}px;">
    <view class="nav-title">鸟圳</view>
    <view class="nav-right">
      <view class="login-badge" wx:if="{{!isLoggedIn}}" bindtap="onLoginTap">
        <image class="badge-icon" src="/images/icons/未登录.png" mode="aspectFit" />
        <text>登录</text>
      </view>
      <view class="login-badge guest" wx:elif="{{isGuest}}">
        <image class="badge-icon" src="/images/icons/未登录.png" mode="aspectFit" />
        <text>访客</text>
      </view>
      <view class="login-badge logged" wx:else>
        <image class="badge-icon" src="/images/icons/登录.png" mode="aspectFit" />
        <text>已登录</text>
      </view>
      <view class="score-badge">
        <text>💰</text>
        <text>{{user.totalScore}}</text>
      </view>
      <view class="save-btn" bindtap="onSaveTap">保存</view>
    </view>
  </view>

  <view class="content-wrapper">
    <scroll-view scroll-y class="scrollarea" scroll-top="{{guideScrollTop}}" scroll-with-animation>
      <view class="container">
        <!-- 每日推荐 -->
        <view class="section-title">{{isDueReview ? '待复习' : '每日推荐'}}</view>
        <view class="card daily-recommend" bindtap="onRecommendTap" wx:if="{{recommendBird}}">
          <view class="recommend-row">
            <image class="recommend-img" src="{{recommendBird.cover}}" mode="aspectFill" />
            <view class="recommend-info">
              <view class="recommend-name">{{recommendBird.name}}</view>
              <view class="recommend-hook">{{recommendHook}}</view>
            </view>
          </view>
        </view>

        <!-- 待复习 -->
        <block wx:if="{{!isDueReview}}">
          <view wx:if="{{dueReviews.length > 0}}" class="section-title">待复习</view>
          <view class="card daily-recommend due-review" wx:for="{{dueReviews}}" wx:key="id" bindtap="onDueReviewTap" data-bird-id="{{item.id}}">
            <view class="recommend-row">
              <image class="recommend-img" src="{{item.cover}}" mode="aspectFill" />
              <view class="recommend-info">
                <view class="recommend-name">{{item.name}}</view>
                <view class="recommend-hook">复习进度 {{item.progress}}/5，点击开始复习</view>
              </view>
            </view>
          </view>
        </block>

        <!-- 宠物展示区 -->
        <view class="section-title">宠物养成</view>
        <view class="card pet-card">
          <view wx:if="{{!pet}}" class="pet-empty">
            <image class="pet-egg" src="/images/unclaimed_egg.png" mode="aspectFit" />
            <view class="title-md">还没有宠物鸟</view>
            <view class="text-sm">领养一颗鸟蛋，开启你的鸟类之旅</view>
            <button class="btn-primary adopt-btn" bindtap="onAdoptTap">领养鸟蛋</button>
          </view>
          <view wx:else class="pet-show">
            <image class="pet-avatar {{stageInfo.key}}" src="{{petImage}}" mode="aspectFit" />
            <view class="pet-info">
              <view class="title-md">{{stageInfo.label}}</view>
              <view class="text-sm">经验 {{currentExp}} / {{stageInfo.nextExpLabel}}</view>
            </view>
            <view class="progress-bar" wx:if="{{!stageInfo.isMax}}">
              <view class="progress-fill" style="width: {{currentExp / stageInfo.nextExp * 100}}%"></view>
            </view>
            <view wx:else class="max-badge">已满级</view>
            <button class="btn-secondary feed-btn" bindtap="onFeedTap">
              立即喂食
            </button>
          </view>
        </view>

        <!-- 学习统计 -->
        <view class="section-title">学习统计</view>
        <view class="card stats-card">
          <view class="stats-row">
            <view class="stats-item">
              <view class="stats-num">{{learnedCount}}<text class="stats-total">/{{totalBirds}}</text></view>
              <view class="stats-label">正在学习</view>
            </view>
            <view class="stats-divider"></view>
            <view class="stats-item">
              <view class="stats-num">{{masteredCount}}<text class="stats-total">/{{totalBirds}}</text></view>
              <view class="stats-label">已精通</view>
            </view>
          </view>
          <view class="stats-progress-bar">
            <view class="stats-progress-fill" style="width: {{learnProgress}}%"></view>
          </view>
          <view class="stats-progress-text">图鉴进度 {{learnProgress}}%</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 每日推荐卡片弹窗 -->
  <view class="card-modal" wx:if="{{showRecommendCard}}" bindtap="onMaskTap">
    <view class="card-modal-content" bindtap="onContentTap">
      <view class="bird-header-modal">
        <image class="bird-emoji" src="{{recommendBird.cover}}" mode="aspectFill" wx:if="{{recommendBird.cover}}" />
        <view class="bird-name" wx:else>{{recommendBird.name}}</view>
        <view class="bird-tags">
          <text wx:for="{{recommendBird.tags}}" wx:key="index">{{item}}{{(index < recommendBird.tags.length - 1) ? ' · ' : ''}}</text>
        </view>
      </view>
      <view class="knowledge-card-modal">
        <view class="knowledge-section">
          <view class="knowledge-section-title">人设</view>
          <view class="knowledge-text">{{recommendBird.persona}}</view>
        </view>
        <view class="knowledge-section">
          <view class="knowledge-section-title">辨识</view>
          <view class="knowledge-text">{{recommendBird.identification}}</view>
        </view>
        <view class="knowledge-section">
          <view class="knowledge-section-title">习性</view>
          <view class="knowledge-text">{{recommendBird.habit}}</view>
        </view>
        <view class="knowledge-section">
          <view class="knowledge-section-title">冷知识</view>
          <view class="knowledge-text">{{recommendBird.trivia}}</view>
        </view>
      </view>
      <button class="btn-primary card-btn" bindtap="onStartQuizTap">开始答题</button>
    </view>
  </view>

  <!-- 引导遮罩 -->
  <view wx:if="{{guideStep >= 0}}">
    <view class="guide-mask" catchtap="onGuideMaskTap" style="top: 0; left: 0; width: 100vw; height: {{guideTop}}px;"></view>
    <view class="guide-mask" catchtap="onGuideMaskTap" style="top: {{guideTop}}px; left: 0; width: {{guideLeft}}px; height: {{guideHeight}}px;"></view>
    <view class="guide-mask" catchtap="onGuideMaskTap" style="top: {{guideTop}}px; left: {{guideRight}}px; width: {{guideRightWidth}}px; height: {{guideHeight}}px;"></view>
    <view class="guide-mask" catchtap="onGuideMaskTap" style="top: {{guideBottom}}px; left: 0; width: 100vw; height: {{guideBottomHeight}}px;"></view>
    <!-- 底部 Tab Bar 遮罩 -->
    <view class="guide-mask guide-mask-tabbar" catchtap="onGuideMaskTap" style="left: 0; width: 100vw;"></view>

    <!-- 高亮边框 -->
    <view class="guide-highlight" style="top: {{guideTop - 8}}px; left: {{guideLeft - 8}}px; width: {{guideWidth + 16}}px; height: {{guideHeight + 16}}px;"></view>

    <!-- 气泡 -->
    <view class="guide-tooltip {{guideTooltipPos}}" style="{{guideTooltipStyle}}">
      <view class="guide-tooltip-arrow"></view>
      <view class="guide-tooltip-inner">
        <view class="guide-tooltip-text">{{guideText}}</view>
        <view class="guide-tooltip-right">
          <view class="guide-step-badge">{{guideStep + 1}}/3</view>
          <view class="guide-skip-link" catchtap="onSkipGuide">跳过</view>
        </view>
      </view>
    </view>
  </view>
</view>
