.page {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: transparent;
}

.nav-bar {
  padding-bottom: 20rpx;
  padding-left: 30rpx;
  background: transparent;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.back-btn {
  font-size: 40rpx;
  width: 60rpx;
  color: #5D4037;
  font-weight: 700;
}

.nav-title {
  font-size: 40rpx;
  font-weight: 700;
  flex: 1;
  text-align: center;
  opacity: 0;
}

.content-wrapper {
  flex: 1;
  overflow: hidden;
  position: relative;
}

.scrollarea {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.container {
  padding-top: 100rpx;
}

.wallet {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.score-badge {
  background: #FFFFFF;
}

.stock-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: #FFFFFF;
  color: var(--primary);
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  margin-top: 20rpx;
  color: #5D4037;
}

.shop-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.shop-item {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  padding: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  backdrop-filter: blur(4rpx);
}

.shop-item.coming-soon {
  opacity: 0.5;
}

.item-icon {
  font-size: 72rpx;
  margin-bottom: 8rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
  color: #5D4037;
}

.item-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.item-price {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 600;
  margin-bottom: 10rpx;
}

.buy-btn {
  background: var(--primary);
  color: #fff;
  border-radius: 48rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
}

.buy-btn::after {
  border: none;
}
