.page {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: transparent;
}

.nav-bar {
  padding-bottom: 20rpx;
  padding-left: 30rpx;
  background: transparent;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.back-btn {
  font-size: 40rpx;
  width: 60rpx;
  color: #5D4037;
  font-weight: 700;
  text-shadow: 0 2rpx 4rpx rgba(255,255,255,0.6);
}

.nav-title {
  font-size: 40rpx;
  font-weight: 700;
  flex: 1;
  text-align: center;
  opacity: 0;
}

.content-wrapper {
  flex: 1;
  overflow: hidden;
  position: relative;
}

.scrollarea {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.container {
  padding-top: 135rpx;
}

.wallet {
  display: flex;
  gap: 16rpx;
  margin-top: -40rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.score-badge {
  background: #FFFFFF;
}

.stock-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: #FFFFFF;
  color: var(--primary);
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  margin-top: 20rpx;
  color: #5D4037;
}

.shop-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 10rpx;
}

.shop-grid + .shop-grid {
  margin-top: 25rpx;
}

.shop-grid:last-child {
  margin-top: 30rpx;
}

.shop-item {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  padding: 80rpx 8rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  backdrop-filter: blur(4rpx);
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
}

.shop-item.coming-soon {
  opacity: 0.5;
}

.item-icon {
  font-size: 64rpx;
  margin-bottom: 2rpx;
}

.item-img {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 8rpx;
  display: block;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 2rpx;
  color: #5D4037;
}

.item-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.item-price {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 600;
  margin-bottom: 4rpx;
}
