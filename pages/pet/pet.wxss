page { background: transparent; overflow: hidden; }

.page { display: flex; flex-direction: column; height: calc(100vh - 75rpx - env(safe-area-inset-bottom)); position: relative; overflow: hidden; }

.bg-image { z-index: 0; }

.nav-bar,
.top-info,
.pet-center,
.bottom-panel {
  position: relative;
  z-index: 1;
}

.nav-bar {
  padding-bottom: 10rpx;
  padding-left: 30rpx;
  background: transparent;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
}

/* 顶部信息区：score-badge + 鸟舍按钮 + 商店按钮 */
.top-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 0 30rpx 10rpx;
  background: transparent;
  flex-shrink: 0;
}

.score-badge {
  font-size: 30rpx;
  padding: 14rpx 28rpx;
}

.shed-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(76, 175, 130, 0.12);
  color: var(--primary);
  padding: 14rpx 28rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.shop-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(232, 112, 91, 0.12);
  color: var(--accent);
  padding: 14rpx 28rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* 中间区域：宠物展示，垂直居中 */
.pet-center {
  flex: 1 1 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 140rpx;
  overflow: hidden;
}

.pet-empty {
  text-align: center;
  padding: 8rpx;
}

.pet-emoji {
  font-size: 120rpx;
  margin-bottom: 4rpx;
  display: block;
}

.adopt-btn {
  margin-top: 10rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
}

.pet-avatar-wrap {
  text-align: center;
  padding: 8rpx 0;
}

.pet-avatar {
  width: 500rpx;
  height: 500rpx;
  display: inline-block;
  transition: transform 0.3s ease;
  line-height: 1;
}

.pet-avatar.egg {
  animation: float 3s ease-in-out infinite;
}

.pet-avatar.chick {
  animation: bounce 2s ease-in-out infinite;
}

.pet-avatar.adult {
  animation: bounce 2.5s ease-in-out infinite;
}

.pet-avatar.ultimate {
  animation: float 4s ease-in-out infinite;
}

.stage-label {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary);
}

.bottom-panel {
  padding: 8rpx 30rpx;
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
  background: transparent;
  flex-shrink: 0;
}

.bottom-panel .card {
  padding: 20rpx;
}

.bottom-panel .card:last-child {
  margin-bottom: 0;
}

.exp-card {
  margin-bottom: 0;
}

.progress-bar {
  height: 10rpx;
  background: rgba(76, 175, 130, 0.15);
  border-radius: 5rpx;
  overflow: hidden;
  margin-top: 6rpx;
}

.progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 5rpx;
  transition: width 0.5s ease;
}

.max-badge {
  text-align: center;
  padding: 6rpx;
  background: var(--secondary);
  border-radius: 12rpx;
  font-weight: 700;
  color: #8A6A00;
  margin-top: 6rpx;
  font-size: 22rpx;
}

.price-tag {
  background: var(--secondary);
  color: #8A6A00;
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  font-weight: 700;
  font-size: 22rpx;
}

.stock-tag {
  background: rgba(76, 175, 130, 0.12);
  color: var(--primary);
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  font-weight: 700;
  font-size: 22rpx;
}

.stock-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.feed-card {
  margin-bottom: 0;
}

.feed-action-btn {
  margin-top: 8rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-16rpx);
  }
}

@keyframes bounce {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.08);
  }
}
