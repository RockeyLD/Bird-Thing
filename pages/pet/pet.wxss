page { background: transparent; overflow: hidden; }

.page { display: flex; flex-direction: column; height: calc(100vh - 100rpx - env(safe-area-inset-bottom)); position: relative; overflow: hidden; }

.bg-image { z-index: 0; }

.nav-bar,
.top-info,
.pet-center,
.bottom-panel {
  position: relative;
  z-index: 1;
}

.nav-bar {
  padding-bottom: 10rpx;
  padding-left: 30rpx;
  background: transparent;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
}

/* 顶部信息区：score-badge + 鸟舍按钮 + 商店按钮 */
.top-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 0 30rpx 10rpx;
  background: transparent;
  flex-shrink: 0;
}

.score-badge {
  font-size: 30rpx;
  padding: 14rpx 28rpx;
}

.shed-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(76, 175, 130, 0.12);
  color: var(--primary);
  padding: 14rpx 28rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.shop-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(232, 112, 91, 0.12);
  color: var(--accent);
  padding: 14rpx 28rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* 中间区域：宠物展示，垂直居中 */
.pet-center {
  flex: 1 1 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 140rpx;
  overflow: hidden;
}

.pet-empty {
  text-align: center;
  padding: 8rpx;
}

.pet-emoji {
  font-size: 120rpx;
  margin-bottom: 4rpx;
  display: block;
}

.adopt-btn {
  margin-top: 10rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
}

.pet-avatar-wrap {
  text-align: center;
  padding: 8rpx 0;
}

.pet-avatar {
  width: 420rpx;
  height: 420rpx;
  display: inline-block;
  transition: transform 0.3s ease;
  line-height: 1;
}

.pet-avatar.egg {
  animation: float 3s ease-in-out infinite;
}

.pet-avatar.chick {
  animation: bounce 2s ease-in-out infinite;
}

.pet-avatar.adult {
  animation: bounce 2.5s ease-in-out infinite;
}

.pet-avatar.ultimate {
  animation: float 4s ease-in-out infinite;
}

.stage-label {
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.4);
  background: rgba(76, 175, 130, 0.85);
  padding: 10rpx 32rpx;
  border-radius: 28rpx;
  display: inline-block;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.bottom-panel {
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: transparent;
  flex-shrink: 0;
  margin-top: 80rpx;
}

.bottom-panel .card {
  padding: 20rpx;
}

.bottom-panel .card:last-child {
  margin-bottom: 0;
}

.exp-card {
  margin-bottom: 20rpx;
}

.progress-bar {
  height: 10rpx;
  background: rgba(76, 175, 130, 0.15);
  border-radius: 5rpx;
  overflow: hidden;
  margin-top: 6rpx;
}

.progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 5rpx;
  transition: width 0.5s ease;
}

.max-badge {
  text-align: center;
  padding: 6rpx;
  background: var(--secondary);
  border-radius: 12rpx;
  font-weight: 700;
  color: #8A6A00;
  margin-top: 6rpx;
  font-size: 22rpx;
}

.price-tag {
  background: var(--secondary);
  color: #8A6A00;
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  font-weight: 700;
  font-size: 22rpx;
}

.stock-tag {
  background: rgba(76, 175, 130, 0.12);
  color: var(--primary);
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  font-weight: 700;
  font-size: 22rpx;
}

.stock-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.feed-card {
  margin-bottom: 0;
}

.feed-action-btn {
  margin-top: 8rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
}

/* 喂食弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.modal-content {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  width: 100%;
  max-width: 640rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 30rpx;
  color: #5D4037;
}

.modal-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.modal-item {
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(93, 64, 55, 0.1);
  border-radius: 24rpx;
  padding: 20rpx 8rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.modal-img {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 8rpx;
  display: block;
}

.modal-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #5D4037;
  margin-bottom: 4rpx;
}

.modal-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.modal-stock {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 600;
}

.modal-empty {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-secondary);
}

.modal-close {
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  border-radius: 36rpx;
  background: rgba(93, 64, 55, 0.08);
  color: #5D4037;
  border: none;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-16rpx);
  }
}

@keyframes bounce {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.08);
  }
}

/* 升级弹窗 */
.levelup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #E8F5E9;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.levelup-content {
  text-align: center;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.levelup-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #2E7D32;
  margin-bottom: 20rpx;
}

.levelup-subtitle {
  font-size: 36rpx;
  font-weight: 600;
  color: #388E3C;
  margin-bottom: 40rpx;
}

.levelup-image {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 40rpx;
}

.levelup-hint {
  font-size: 28rpx;
  color: #66BB6A;
  margin-bottom: 60rpx;
}

.levelup-btn {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  background: #4CAF82;
  border-radius: 44rpx;
  padding: 0 80rpx;
  border: none;
}
