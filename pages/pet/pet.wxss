page { background: transparent; }

.page { display: flex; flex-direction: column; height: calc(100vh - 100rpx - env(safe-area-inset-bottom)); position: relative; }

.bg-image { z-index: 0; }

.nav-bar,
.top-info,
.pet-center,
.bottom-panel {
  position: relative;
  z-index: 1;
}

.nav-bar {
  padding-bottom: 20rpx;
  padding-left: 30rpx;
  background: var(--bg);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.nav-title {
  font-size: 40rpx;
  font-weight: 700;
}

/* 顶部信息区：score-badge + 鸟舍按钮 */
.top-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
  padding: 0 30rpx 16rpx;
  background: var(--bg);
  flex-shrink: 0;
}

.shed-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(76, 175, 130, 0.12);
  color: var(--primary);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* 中间区域：宠物展示，垂直居中 */
.pet-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 0;
  overflow: hidden;
}

.pet-empty {
  text-align: center;
  padding: 12rpx;
}

.pet-emoji {
  font-size: 180rpx;
  margin-bottom: 8rpx;
  display: block;
}

.adopt-btn {
  margin-top: 16rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
}

.pet-avatar-wrap {
  text-align: center;
  padding: 12rpx 0;
}

.pet-avatar {
  font-size: 200rpx;
  display: inline-block;
  transition: transform 0.3s ease;
  line-height: 1;
}

.pet-avatar.egg {
  animation: float 3s ease-in-out infinite;
}

.pet-avatar.chick {
  animation: bounce 2s ease-in-out infinite;
}

.pet-avatar.adult {
  animation: bounce 2.5s ease-in-out infinite;
}

.pet-avatar.elder {
  animation: float 4s ease-in-out infinite;
}

.stage-label {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary);
}

.bottom-panel {
  padding: 12rpx 30rpx;
  background: var(--bg);
  flex-shrink: 0;
}

.exp-card {
  margin-bottom: 12rpx;
}

.progress-bar {
  height: 12rpx;
  background: rgba(76, 175, 130, 0.15);
  border-radius: 6rpx;
  overflow: hidden;
  margin-top: 8rpx;
}

.progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.max-badge {
  text-align: center;
  padding: 8rpx;
  background: var(--secondary);
  border-radius: 16rpx;
  font-weight: 700;
  color: #8A6A00;
  margin-top: 8rpx;
}

.price-tag {
  background: var(--secondary);
  color: #8A6A00;
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  font-weight: 700;
  font-size: 22rpx;
}

.feed-card {
  margin-bottom: 12rpx;
}

.feed-action-btn {
  margin-top: 12rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
}

.release-card {
  margin-bottom: 12rpx;
  border: 2rpx solid var(--accent);
}

.release-action-btn {
  margin-top: 12rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  background: var(--accent);
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-16rpx);
  }
}

@keyframes bounce {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.08);
  }
}
