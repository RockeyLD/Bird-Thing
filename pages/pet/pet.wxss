.page { display: flex; flex-direction: column; height: 100vh; }

.nav-bar { padding: 120rpx 30rpx 20rpx; background: var(--bg); display: flex; justify-content: space-between; align-items: center; }
.nav-title { font-size: 40rpx; font-weight: 700; }

.content-wrapper { flex: 1; overflow: hidden; }
.scrollarea { height: 100%; }

.pet-empty { text-align: center; padding: 80rpx 40rpx; }
.pet-emoji { font-size: 140rpx; margin-bottom: 20rpx; }

.pet-stage { padding: 20rpx 0; }

.pet-avatar-wrap {
  text-align: center;
  padding: 40rpx 0;
}

.pet-avatar {
  font-size: 200rpx;
  display: inline-block;
  transition: transform 0.3s ease;
}

.pet-avatar.egg { animation: float 3s ease-in-out infinite; }
.pet-avatar.chick { animation: bounce 2s ease-in-out infinite; }
.pet-avatar.adult { animation: bounce 2.5s ease-in-out infinite; }
.pet-avatar.elder { animation: float 4s ease-in-out infinite; }

.stage-label {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
}

.exp-card { margin-bottom: 24rpx; }

.progress-bar {
  height: 20rpx;
  background: rgba(76, 175, 130, 0.15);
  border-radius: 10rpx;
  overflow: hidden;
  margin-top: 16rpx;
}

.progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.max-badge {
  text-align: center;
  padding: 20rpx;
  background: var(--secondary);
  border-radius: 16rpx;
  font-weight: 700;
  color: #8A6A00;
  margin-top: 16rpx;
}

.price-tag {
  background: var(--secondary);
  color: #8A6A00;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-weight: 700;
  font-size: 24rpx;
}

.feed-card { margin-bottom: 24rpx; }
.release-card { margin-bottom: 24rpx; border: 2rpx solid var(--accent); }

.section-title { font-size: 32rpx; font-weight: 700; margin: 30rpx 0 20rpx; }

.shed-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.shed-item {
  background: var(--card);
  border-radius: 20rpx;
  padding: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.shed-emoji { font-size: 60rpx; }

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}
@keyframes bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}
