.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg);
}

.nav-bar {
  padding-bottom: 20rpx;
  padding-left: 30rpx;
  background: var(--bg);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.nav-title {
  font-size: 40rpx;
  font-weight: 700;
}

/* 顶部信息区：score-badge + 鸟舍按钮 */
.top-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
  padding: 0 30rpx 16rpx;
  background: var(--bg);
  flex-shrink: 0;
}

.shed-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(76, 175, 130, 0.12);
  color: var(--primary);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* 鸟舍展开面板 */
.shed-panel {
  background: var(--bg);
  padding: 0 30rpx 20rpx;
  max-height: 320rpx;
  overflow-y: auto;
  flex-shrink: 0;
}

.shed-panel-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--text);
}

.shed-empty {
  text-align: center;
  padding: 40rpx 0;
  grid-column: 1 / -1;
}

.shed-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.shed-item {
  background: var(--card);
  border-radius: 20rpx;
  padding: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.shed-emoji {
  font-size: 60rpx;
}

/* 中间区域：宠物展示，垂直居中 */
.pet-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 0;
  overflow: hidden;
}

.pet-empty {
  text-align: center;
  padding: 40rpx;
}

.pet-emoji {
  font-size: 320rpx;
  margin-bottom: 20rpx;
  display: block;
}

.adopt-btn {
  margin-top: 40rpx;
}

.pet-avatar-wrap {
  text-align: center;
  padding: 40rpx 0;
}

.pet-avatar {
  font-size: 360rpx;
  display: inline-block;
  transition: transform 0.3s ease;
  line-height: 1;
}

.pet-avatar.egg {
  animation: float 3s ease-in-out infinite;
}

.pet-avatar.chick {
  animation: bounce 2s ease-in-out infinite;
}

.pet-avatar.adult {
  animation: bounce 2.5s ease-in-out infinite;
}

.pet-avatar.elder {
  animation: float 4s ease-in-out infinite;
}

.stage-label {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

/* 底部固定面板 */
.bottom-panel {
  padding: 20rpx 30rpx 30rpx;
  background: var(--bg);
  flex-shrink: 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.exp-card {
  margin-bottom: 24rpx;
}

.progress-bar {
  height: 20rpx;
  background: rgba(76, 175, 130, 0.15);
  border-radius: 10rpx;
  overflow: hidden;
  margin-top: 16rpx;
}

.progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.max-badge {
  text-align: center;
  padding: 20rpx;
  background: var(--secondary);
  border-radius: 16rpx;
  font-weight: 700;
  color: #8A6A00;
  margin-top: 16rpx;
}

.price-tag {
  background: var(--secondary);
  color: #8A6A00;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-weight: 700;
  font-size: 24rpx;
}

.feed-card {
  margin-bottom: 24rpx;
}

.feed-action-btn {
  margin-top: 24rpx;
}

.release-card {
  margin-bottom: 24rpx;
  border: 2rpx solid var(--accent);
}

.release-action-btn {
  margin-top: 24rpx;
  background: var(--accent);
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-16rpx);
  }
}

@keyframes bounce {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.08);
  }
}
