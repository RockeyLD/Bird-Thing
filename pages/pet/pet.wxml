<view class="page">
  <image class="bg-image" src="{{petBg}}" mode="aspectFill" />
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px; padding-right: {{menuButtonRight}}px;">
    <view class="nav-title">宠物养成</view>
  </view>

  <view class="top-info" style="margin-top: {{scoreBarOffset}}px;">
    <view class="score-badge">💰 {{user.totalScore}}</view>
    <view class="shed-btn" bindtap="goToShed">🦜 鸟舍</view>
    <view class="shop-btn" bindtap="goToShop">🛒 商店</view>
  </view>

  <!-- 中间区域：鸟蛋/宠物，在剩余空间垂直居中 -->
  <view class="pet-center">
    <view wx:if="{{!pet}}" class="pet-empty">
      <view class="pet-emoji">🥚</view>
      <view class="title-lg">还没有宠物鸟</view>
      <view class="text-sm">领养一颗鸟蛋，开始你的养成之旅</view>
      <button class="btn-primary adopt-btn" bindtap="onAdoptTap">领养鸟蛋</button>
    </view>

    <view wx:else class="pet-avatar-wrap">
      <image class="pet-avatar {{stageInfo.key}}" src="{{petImage}}" mode="aspectFit" />
      <view class="stage-label">{{stageInfo.label}}</view>
    </view>
  </view>

  <!-- 底部固定面板：经验值 + 食物 -->
  <view wx:if="{{pet}}" class="bottom-panel">
    <!-- 经验进度 -->
    <view class="card exp-card">
      <view class="flex-between">
        <text class="title-md">经验值</text>
        <text wx:if="{{!stageInfo.isMax}}" class="text-sm">{{currentExp}} / {{stageInfo.reqExp}}</text>
        <text wx:else class="text-sm">MAX</text>
      </view>
      <view class="progress-bar" wx:if="{{!stageInfo.isMax}}">
        <view class="progress-fill" style="{{progressStyle}}"></view>
      </view>
      <view wx:else class="max-badge">已满级</view>
    </view>

    <!-- 喂食 -->
    <view class="card feed-card">
      <view class="stock-row">
        <view class="stock-tag">🌾 总库存: {{feedStock}}</view>
        <view wx:if="{{user.feedInventory.fruit && feedStock > 0}}" class="stock-tag">🍈 果实: {{user.feedInventory.fruit}}</view>
        <view wx:if="{{user.feedInventory.worm && feedStock > 0}}" class="stock-tag">🪱 蚯蚓: {{user.feedInventory.worm}}</view>
        <view wx:if="{{user.feedInventory.beetle && feedStock > 0}}" class="stock-tag">🪲 甲虫: {{user.feedInventory.beetle}}</view>
        <view wx:if="{{user.feedInventory.mouse && feedStock > 0}}" class="stock-tag">🐭 田鼠: {{user.feedInventory.mouse}}</view>
        <view wx:if="{{user.feedInventory.rabbit && feedStock > 0}}" class="stock-tag">🐰 野兔: {{user.feedInventory.rabbit}}</view>
        <view wx:if="{{user.feedInventory.fox && feedStock > 0}}" class="stock-tag">🦊 狐狸: {{user.feedInventory.fox}}</view>
        <view wx:if="{{user.feedInventory.ant && feedStock > 0}}" class="stock-tag">🐜 蚂蚁: {{user.feedInventory.ant}}</view>
        <view wx:if="{{user.feedInventory.caterpillar && feedStock > 0}}" class="stock-tag">🐛 毛毛虫: {{user.feedInventory.caterpillar}}</view>
        <view wx:if="{{user.feedInventory.fig && feedStock > 0}}" class="stock-tag">🍈 榕树果实: {{user.feedInventory.fig}}</view>
      </view>
      <button wx:if="{{!stageInfo.isMax}}" class="btn-primary feed-action-btn" bindtap="onFeedTap">立即喂食</button>
      <button wx:else class="btn-primary feed-action-btn retire-btn" bindtap="onRetireTap">移居鸟舍</button>
    </view>
  </view>

  <!-- 喂食选择弹窗 -->
  <view wx:if="{{showFeedModal}}" class="modal-overlay" bindtap="hideFeedModal">
    <view class="modal-content" catchtap="onModalTap">
      <view class="modal-title">选择食物</view>
      <view class="modal-grid">
        <view wx:for="{{modalFeeds}}" wx:key="key" class="modal-item" bindtap="onSelectFeed" data-key="{{item.key}}">
          <image class="modal-img" src="{{item.icon}}" mode="aspectFit" />
          <view class="modal-name">{{item.name}}</view>
          <view class="modal-desc">+{{item.exp}} 经验</view>
          <view class="modal-stock">库存: {{item.stock}}</view>
        </view>
      </view>
      <view wx:if="{{modalFeeds.length === 0}}" class="modal-empty">
        <view class="text-sm">没有可用的食物，去商店看看吧～</view>
      </view>
      <button class="btn-secondary modal-close" bindtap="hideFeedModal">取消</button>
    </view>
  </view>

  <!-- 升级弹窗 -->
  <view wx:if="{{showLevelUp}}" class="levelup-overlay">
    <view class="levelup-content">
      <view class="levelup-title">恭喜你升级了！</view>
      <view class="levelup-subtitle">获得{{levelUpText}}！</view>
      <image class="levelup-image" src="{{levelUpImage}}" mode="aspectFit" />
      <view class="levelup-hint">还需{{levelUpReqExp}}经验值可再次升级</view>
      <button class="levelup-btn" bindtap="hideLevelUp">太棒了</button>
    </view>
  </view>
</view>
