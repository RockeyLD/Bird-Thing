<view class="page">
  <image class="bg-image" src="/images/Background.png" mode="aspectFill" />
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px; padding-right: {{menuButtonRight}}px;">
    <view class="nav-title">宠物养成</view>
  </view>

  <view class="top-info" style="margin-top: {{scoreBarOffset}}px;">
    <view class="score-badge">⭐ {{user.totalScore}}</view>
    <view class="shed-btn" bindtap="goToShed">🦜 鸟舍</view>
    <view class="shop-btn" bindtap="goToShop">🛒 商店</view>
  </view>

  <!-- 中间区域：鸟蛋/宠物，在剩余空间垂直居中 -->
  <view class="pet-center">
    <view wx:if="{{!pet}}" class="pet-empty">
      <view class="pet-emoji">🥚</view>
      <view class="title-lg">还没有宠物鸟</view>
      <view class="text-sm">领养一颗鸟蛋，开始你的养成之旅</view>
      <button class="btn-primary adopt-btn" bindtap="onAdoptTap">领养鸟蛋</button>
    </view>

    <view wx:else class="pet-avatar-wrap">
      <view class="pet-avatar {{stageInfo.key}}">
        <text wx:if="{{stageInfo.key === 'egg'}}">🥚</text>
        <text wx:elif="{{stageInfo.key === 'chick'}}">🐣</text>
        <text wx:elif="{{stageInfo.key === 'adult'}}">🐦</text>
        <text wx:elif="{{stageInfo.key === 'elder'}}">🦅</text>
        <text wx:else>🦜✨</text>
      </view>
      <view class="stage-label">{{stageInfo.label}}</view>
    </view>
  </view>

  <!-- 底部固定面板：经验值 + 饲料 -->
  <view wx:if="{{pet}}" class="bottom-panel">
    <!-- 经验进度 -->
    <view class="card exp-card">
      <view class="flex-between">
        <text class="title-md">经验值</text>
        <text class="text-sm">{{pet.exp}} / {{stageInfo.nextExpLabel}}</text>
      </view>
      <view class="progress-bar" wx:if="{{!stageInfo.isMax}}">
        <view class="progress-fill" style="width: {{pet.exp / stageInfo.nextExp * 100}}%"></view>
      </view>
      <view wx:else class="max-badge">已满级</view>
    </view>

    <!-- 喂食 -->
    <view class="card feed-card">
      <view class="flex-between">
        <view>
          <view class="title-md">🌾 基础饲料</view>
          <view class="text-sm">喂食一次 +{{feedExp}} 经验</view>
        </view>
        <view class="stock-tag">库存: {{feedStock}}</view>
      </view>
      <button class="btn-primary feed-action-btn" bindtap="onFeedTap">立即喂食</button>
    </view>

    <!-- 放归 -->
    <view wx:if="{{stageInfo.key === 'max'}}" class="card release-card">
      <view class="title-md">🌳 放归自然</view>
      <view class="text-sm">你的宠物鸟已经达到满级，可以选择放归自然，开启下一只鸟的养成。</view>
      <button class="btn-primary release-action-btn" bindtap="onReleaseTap">放归自然</button>
    </view>
  </view>
</view>
