.page { display: flex; flex-direction: column; height: 100vh; }

.nav-bar { padding-bottom: 20rpx; padding-left: 30rpx; background: var(--bg); display: flex; align-items: center; gap: 20rpx; }
.back-btn { font-size: 40rpx; width: 60rpx; }
.nav-title { font-size: 36rpx; font-weight: 700; flex: 1; }

.dim-tabs {
  display: flex;
  gap: 12rpx;
  padding: 0 30rpx 20rpx;
  background: var(--bg);
  overflow-x: auto;
}

.dim-tab {
  padding: 10rpx 24rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  background: var(--card);
  color: var(--text-secondary);
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.dim-tab.active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
}

.content-wrapper { flex: 1; overflow: hidden; }
.scrollarea { height: 100%; }

.bird-header { text-align: center; padding: 40rpx; }
.bird-emoji { font-size: 100rpx; margin-bottom: 12rpx; }
.bird-tags { margin-top: 16rpx; }

.knowledge-card { margin-bottom: 24rpx; }
.dim-title { font-size: 32rpx; font-weight: 700; margin-bottom: 16rpx; }
.knowledge-text { font-size: 28rpx; line-height: 1.6; color: var(--text-secondary); }

.quiz-card { margin-bottom: 30rpx; }
.quiz-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.quiz-title { font-size: 32rpx; font-weight: 700; }
.dim-tag { background: var(--primary); color: #fff; padding: 6rpx 16rpx; border-radius: 24rpx; font-size: 24rpx; }
.quiz-question { font-size: 28rpx; margin-bottom: 24rpx; line-height: 1.5; }

.options { display: flex; flex-direction: column; gap: 16rpx; }

.option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: var(--bg);
  border-radius: 16rpx;
  font-size: 28rpx;
  transition: all 0.2s;
}

.option:active { background: rgba(76, 175, 130, 0.1); }

.option.correct { background: rgba(76, 175, 130, 0.2); border: 2rpx solid var(--primary); }
.option.wrong { background: rgba(232, 112, 91, 0.15); border: 2rpx solid var(--accent); }

.opt-letter {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.option.correct .opt-letter { background: var(--primary); }
.option.wrong .opt-letter { background: var(--accent); }

.card-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(0,0,0,0.5);
}

.card-modal-content {
  background: var(--card);
  border-radius: 24rpx;
  padding: 40rpx;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
}

.bird-header-modal { text-align: center; padding: 20rpx 0 30rpx; }
.bird-header-modal .bird-emoji { font-size: 100rpx; margin-bottom: 12rpx; }
.bird-header-modal .bird-tags { margin-top: 16rpx; }

.knowledge-card-modal { padding: 24rpx 0; border-top: 1rpx solid rgba(0,0,0,0.06); }
.knowledge-card-modal .dim-title { font-size: 32rpx; font-weight: 700; margin-bottom: 16rpx; }
.knowledge-card-modal .knowledge-text { font-size: 28rpx; line-height: 1.6; color: var(--text-secondary); }

.card-modal-content .btn-primary { margin-top: 20rpx; width: 100%; }
