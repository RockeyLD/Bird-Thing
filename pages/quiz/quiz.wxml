<view class="page">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px; padding-right: {{menuButtonRight}}px;">
    <view class="back-btn" bindtap="onBackTap">←</view>
    <view class="nav-title">{{bird.name}}</view>
    <view class="score-badge">⭐ {{user.totalScore}}</view>
  </view>

  <!-- 鸟类知识卡片弹窗 -->
  <view wx:if="{{showCard}}" class="card-modal" catchtap="onMaskTap">
    <view class="card-modal-content" catchtap="onContentTap">
      <view class="bird-header-modal">
        <image wx:if="{{bird.cover}}" class="bird-cover-img" src="{{bird.cover}}" mode="aspectFit" />
        <view wx:else class="bird-emoji">🐦</view>
        <view class="title-lg">{{bird.name}}</view>
        <view class="text-sm">{{bird.enName}}</view>
        <view class="bird-tags">
          <text class="tag" wx:for="{{bird.tags}}" wx:for-item="t" wx:key="*this">{{t}}</text>
        </view>
      </view>
      <view class="knowledge-card-modal">
        <view class="dim-title">{{dimension.icon}} {{dimension.label}}</view>
        <view class="knowledge-text">{{bird.desc}}</view>
      </view>
      <button class="btn-primary" bindtap="onStartQuiz">开始答题</button>
    </view>
  </view>

  <view class="content-wrapper">
    <scroll-view scroll-y class="scrollarea">
      <view class="container">
        <!-- 模拟答题区（题目后续补充） -->
        <view class="card quiz-card">
          <view class="quiz-header">
            <view class="quiz-title">📝 知识问答</view>
            <view class="dim-tag">{{dimension.label}}</view>
          </view>
          <view class="quiz-question">{{bird.name}} 的以下特征，哪个是正确的？</view>
          <view class="options">
            <view class="option {{selected === 0 ? (isCorrect ? 'correct' : 'wrong') : ''}} {{answered && selected !== 0 && isCorrect ? '' : ''}}" bindtap="onOptionTap" data-idx="0">
              <text class="opt-letter">A</text>
              <text>{{bird.tags[0] || '体型较小'}}</text>
            </view>
            <view class="option {{selected === 1 ? (isCorrect ? 'correct' : 'wrong') : ''}}" bindtap="onOptionTap" data-idx="1">
              <text class="opt-letter">B</text>
              <text>生活在深海</text>
            </view>
            <view class="option {{selected === 2 ? (isCorrect ? 'correct' : 'wrong') : ''}}" bindtap="onOptionTap" data-idx="2">
              <text class="opt-letter">C</text>
              <text>以肉类为食</text>
            </view>
            <view class="option {{selected === 3 ? (isCorrect ? 'correct' : 'wrong') : ''}}" bindtap="onOptionTap" data-idx="3">
              <text class="opt-letter">D</text>
              <text>不会飞</text>
            </view>
          </view>
        </view>

        <button wx:if="{{answered}}" class="btn-primary" bindtap="onNextTap">
          {{dimIndex < 4 ? '下一维度 →' : '完成学习'}}
        </button>
      </view>
    </scroll-view>
  </view>
</view>
