<view class="page">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px; padding-right: {{menuButtonRight}}px;">
    <view class="back-btn" bindtap="onBackTap">←</view>
    <view class="nav-title">{{bird.name}}</view>
    <view class="score-badge">⭐ {{user.totalScore}}</view>
  </view>

  <!-- 鸟类知识卡片弹窗 -->
  <view wx:if="{{showCard}}" class="card-modal" catchtap="onMaskTap">
    <view class="card-modal-content" catchtap="onContentTap">
      <view class="bird-header-modal">
        <image wx:if="{{bird.cover}}" class="bird-cover-img" src="{{bird.cover}}" mode="aspectFit" />
        <view wx:else class="bird-emoji">🐦</view>
        <view class="title-lg">{{bird.name}}</view>
        <view class="text-sm">{{bird.enName}}</view>
        <view class="bird-tags">
          <text class="tag" wx:for="{{bird.tags}}" wx:for-item="t" wx:key="*this">{{t}}</text>
        </view>
      </view>
      <view class="knowledge-card-modal">
        <view wx:if="{{bird.persona}}" class="knowledge-section">
          <view class="knowledge-section-title">🎭 人设</view>
          <view class="knowledge-text">{{bird.persona}}</view>
        </view>
        <view wx:if="{{bird.identification}}" class="knowledge-section">
          <view class="knowledge-section-title">👁 辨识</view>
          <view class="knowledge-text">{{bird.identification}}</view>
        </view>
        <view wx:if="{{bird.habit}}" class="knowledge-section">
          <view class="knowledge-section-title">🌿 习性</view>
          <view class="knowledge-text">{{bird.habit}}</view>
        </view>
        <view wx:if="{{bird.trivia}}" class="knowledge-section">
          <view class="knowledge-section-title">💡 冷知识</view>
          <view class="knowledge-text">{{bird.trivia}}</view>
        </view>
        <view wx:if="{{!bird.persona}}" class="knowledge-section">
          <view class="knowledge-text">{{bird.desc}}</view>
        </view>
      </view>
      <button class="btn-primary" bindtap="onStartQuiz">开始答题</button>
    </view>
  </view>

  <view class="content-wrapper">
    <scroll-view scroll-y class="scrollarea">
      <view class="container">
        <!-- 题库模式进度条 -->
        <view wx:if="{{quizMode}}" class="progress-bar">
          <view class="progress-track">
            <view class="progress-fill" style="width: {{correctCount * 20}}%"></view>
          </view>
          <view class="progress-text">{{correctCount}}/5</view>
        </view>

        <!-- 答题区 -->
        <view class="card quiz-card">
          <view class="quiz-header">
            <view class="quiz-title">📝 知识问答</view>
            <view wx:if="{{!quizMode}}" class="dim-tag">{{dimension.label}}</view>
          </view>

          <!-- 题库模式题目 -->
          <view wx:if="{{quizMode && currentQuestion}}">
            <view class="quiz-question">{{currentQuestion.q}}</view>
            <view class="options">
              <view
                class="option {{answered && idx === currentQuestion.a ? 'correct' : ''}} {{answered && selected === idx && !isCorrect ? 'wrong' : ''}}"
                wx:for="{{currentQuestion.options}}"
                wx:for-index="idx"
                wx:key="*this"
                bindtap="onOptionTap"
                data-idx="{{idx}}"
              >
                <text class="opt-letter">{{['A','B','C','D'][idx]}}</text>
                <text>{{item}}</text>
              </view>
            </view>
          </view>

          <!-- 维度模式题目（fallback） -->
          <view wx:if="{{!quizMode}}">
            <view class="quiz-question">{{bird.name}} 的以下特征，哪个是正确的？</view>
            <view class="options">
              <view class="option {{answered && 0 === 0 ? 'correct' : ''}} {{answered && selected === 0 && !isCorrect ? 'wrong' : ''}}" bindtap="onOptionTap" data-idx="0">
                <text class="opt-letter">A</text>
                <text>{{bird.tags[0] || '体型较小'}}</text>
              </view>
              <view class="option {{answered && 0 === 1 ? 'correct' : ''}} {{answered && selected === 1 && !isCorrect ? 'wrong' : ''}}" bindtap="onOptionTap" data-idx="1">
                <text class="opt-letter">B</text>
                <text>生活在深海</text>
              </view>
              <view class="option {{answered && 0 === 2 ? 'correct' : ''}} {{answered && selected === 2 && !isCorrect ? 'wrong' : ''}}" bindtap="onOptionTap" data-idx="2">
                <text class="opt-letter">C</text>
                <text>以肉类为食</text>
              </view>
              <view class="option {{answered && 0 === 3 ? 'correct' : ''}} {{answered && selected === 3 && !isCorrect ? 'wrong' : ''}}" bindtap="onOptionTap" data-idx="3">
                <text class="opt-letter">D</text>
                <text>不会飞</text>
              </view>
            </view>
          </view>
        </view>

        <button wx:if="{{answered}}" class="btn-primary {{isCorrect ? '' : 'btn-danger'}}" bindtap="onNextTap">
          {{isCorrect ? (quizMode ? '下一题' : '下一维度 →') : '退出'}}
        </button>

        <view wx:if="{{showFeedback}}" class="feedback-area {{isCorrect ? 'feedback-correct' : 'feedback-wrong'}}">
          {{feedbackText}}
        </view>
      </view>
    </scroll-view>
  </view>
</view>
