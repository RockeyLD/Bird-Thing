.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  display: flex;
  justify-content: space-around;
  align-items: center;
  border-top: 1rpx solid rgba(0,0,0,0.06);
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100rpx;
  gap: 6rpx;
}

.tab-icon { width: 52rpx; height: 52rpx; opacity: 0.6; transition: opacity 0.2s; }
.tab-text { font-size: 22rpx; color: #8A9A90; transition: color 0.2s; }

.tab-item.active .tab-icon { opacity: 1; }
.tab-item.active .tab-text { color: #4CAF82; font-weight: 600; }
